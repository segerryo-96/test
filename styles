}

/* --- CẤU HÌNH MODAL DARK MODE CHUYÊN NGHIỆP --- */
.config-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(10, 12, 16, 0.85);
  backdrop-filter: blur(6px); /* Làm mờ hậu cảnh phía sau */
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 10000;
  animation: fadeInModal 0.25s ease-out;
}

.config-modal-card {
  background: #181b23;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 16px;
  width: 100%;
  max-width: 420px;
  padding: 28px;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 2px rgba(255, 255, 255, 0.1) inset;
}

.config-modal-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  padding-bottom: 14px;
}

.config-modal-icon {
  font-size: 20px;
}

.config-modal-title {
  color: #ffffff;
  font-size: 19px;
  font-weight: 600;
  margin: 0;
  letter-spacing: 0.5px;
}

.config-modal-body {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 28px;
}

.config-form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.config-form-group label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 13px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.config-input-wrapper input {
  width: 100%;
  background: #0f1115;
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 8px;
  padding: 12px 14px;
  color: #ffffff;
  font-size: 15px;
  font-weight: 500;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.config-input-wrapper input:focus {
  outline: none;
  border-color: #4ade80;
  box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.15);
  background: #12151b;
}

.config-modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
}

.config-btn {
  padding: 11px 22px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: all 0.2s ease;
}

.config-btn-secondary {
  background: transparent;
  color: rgba(255, 255, 255, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.config-btn-secondary:hover {
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
}

.config-btn-primary {
  background: #22c55e;
  color: #052e16;
  box-shadow: 0 4px 12px rgba(34, 197, 94, 0.2);
}

.config-btn-primary:hover {
  background: #4ade80;
  transform: translateY(-1px);
  box-shadow: 0 6px 16px rgba(74, 222, 128, 0.3);
}

.config-btn-primary:active {
  transform: translateY(0);
}

@keyframes fadeInModal {
  from { opacity: 0; transform: scale(0.96); }
  to { opacity: 1; transform: scale(1); }
}

/* --- CSS TOAST NOTIFICATION DARK MODE --- */
.toast-container {
  position: fixed;
  top: 24px;
  right: 24px;
  background: #1e2230;
  border-left: 4px solid #22c55e;
  border-radius: 8px;
  padding: 16px 24px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5), 0 0 1px rgba(255, 255, 255, 0.1) inset;
  z-index: 10001;
  animation: slideInRight 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28);
}

.toast-content {
  display: flex;
  align-items: center;
  gap: 12px;
}

.toast-icon {
  font-size: 18px;
}

.toast-message {
  color: #ffffff;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.3px;
}

/* Hiệu ứng trượt từ phải sang */
@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(100px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* --- CSS ĐẢM BẢO CHỐNG VỠ GIAO DIỆN KHI THU NHỎ TRÌNH DUYỆT --- */

/* 1. Cho phép bảng dữ liệu lớn xuất hiện thanh cuộn ngang độc lập (Không kéo vỡ màn hình chính) */
.main-content, .main-container, .content-wrapper {
  overflow-x: auto; /* Tự xuất hiện thanh cuộn ngang riêng cho bảng nếu màn hình quá hẹp */
  padding: 15px;
  box-sizing: border-box;
}

/* 2. Giữ nguyên kích thước tối thiểu của bảng đơn hàng để chữ không bị tràn, đè lên nhau */
table {
  min-width: 1200px; /* Ép bảng giữ độ rộng chuẩn để các cột hiển thị đẹp mắt */
  width: 100%;
  border-collapse: collapse;
}

/* 3. Tự động co giãn hoặc xếp chồng thanh công cụ (Bộ lọc ngày, Tìm kiếm, Tab) khi màn hình hẹp dưới 1200px */
@media screen and (max-width: 1200px) {
  
  /* Gom cụm các tab bộ lọc trạng thái tự động xuống dòng nếu thiếu chỗ */
  .filter-tabs-container, .tabs-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 15px;
  }
  
  /* Tự động chuyển hàng ngang chứa (Ô lịch + Ô tìm kiếm) thành dạng linh hoạt */
  .toolbar, .filter-box, .date-box-parent {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    width: 100%;
  }

  /* Cho phép các ô input và ô lịch phình rộng hoặc thu hẹp tự nhiên */
  .date-box input[type="date"], 
  #search-input {
    flex: 1;
    min-width: 130px; /* Không cho phép thu nhỏ quá mức này */
  }

