  /* Thiết kế lại các nút bấm phân trang phong cách Gaming mượt mà */
  .page-btn {
    min-width: 36px;
    height: 36px;
    padding: 0 10px;
    background-color: #1a1d26 !important; /* Màu nền tối sâu cùng tông với bảng */
    color: #a0aec0 !important; /* Chữ màu xám nhẹ */
    border: 1px solid #2d323f !important; /* Viền mờ */
    border-radius: 8px !important; /* Bo góc mềm mại */
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Hiệu ứng khi rê chuột qua các nút (Chừa nút đang bị khóa) */
  .page-btn:hover:not(:disabled) {
    border-color: #4ade80 !important; /* Viền sáng xanh lá neon */
    color: #4ade80 !important; /* Chữ đổi sang xanh lá */
    background-color: rgba(74, 222, 128, 0.05) !important; /* Nền ửng xanh nhẹ */
    transform: translateY(-1px); /* Nút nhấc nhẹ lên tạo chiều sâu */
