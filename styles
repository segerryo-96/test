  }

  /* --- ĐOẠN 2: Hiệu ứng sáng nhẹ hàng khi di chuột qua, giúp nhìn không bị lệch dòng --- */
  tbody tr:hover {
    background-color: rgba(255, 255, 255, 0.04) !important; /* Nền hàng sáng lên một chút tinh tế */
