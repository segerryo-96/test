/* --- HỆ THỐNG Sidebar ẨN / HIỆN TOÀN PHẦN CỐ ĐỊNH --- */
.sidebar {
  width: 240px; /* Độ rộng gốc của thanh menu */
  position: fixed; /* Ép cố định bên trái */
  top: 0;
  left: 0;
  height: 100vh;
  z-index: 999;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* Hiệu ứng trượt êm ái */
}

/* Khi kích hoạt chế độ ẩn: Đẩy toàn bộ menu thụt hẳn ra ngoài mép trái màn hình */
.sidebar.collapsed {
  transform: translateX(-240px);
}

/* NÚT BẤM NỔI BỀ MẶT CỐ ĐỊNH Ở MÉP TRÁI MÀN HÌNH */
.toggle-sidebar-floating-btn {
  position: fixed;
  left: 240px; /* Ban đầu bám sát mép Sidebar */
  top: 15px;
  background-color: #2d3748;
  border: 1px solid #4a5568;
  color: #a0aec0;
  border-radius: 0 4px 4px 0; /* Tạo bo góc dạng tab ở bên phải */
  width: 20px;
  height: 35px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  z-index: 1000; /* Luôn luôn nằm trên cùng */
  transition: all 0.3s ease;
  box-shadow: 2px 0 5px rgba(0,0,0,0.3);
}

.toggle-sidebar-floating-btn:hover {
  color: #fff;
  background-color: #4a5568;
}

/* Khi Sidebar ẩn hoàn toàn: Dịch nút bấm sát về lề trái 0px và đảo chiều mũi tên */
.sidebar.collapsed ~ .toggle-sidebar-floating-btn,
body:has(.sidebar.collapsed) .toggle-sidebar-floating-btn {
  left: 0px !important;
}

/* KHỐI NỘI DUNG BẢNG LỚN BÊN PHẢI */
.main-content, .main-container, .content {
  margin-left: 240px; /* Trừ khoảng trống menu ban đầu */
