}

/* Khi menu ẩn dứt điểm: Bảng tự động tràn viền rộng 100% ra sát mép màn hình */
.sidebar.collapsed ~ .main-content,
.sidebar.collapsed ~ .main-container,
body:has(.sidebar.collapsed) .main-content {
  margin-left: 0px !important;
  width: 100% !important;
}



