  /* Trạng thái nút của Trang Hiện Tại đang xem (Active) */
  .page-btn.active {
    background-color: #4ade80 !important; /* Đổi hẳn nền sang xanh lá thương hiệu */
    color: #0b0d12 !important; /* Chữ màu tối để nổi bật trên nền xanh */
    font-weight: 600 !important;
    border-color: #4ade80 !important;
    box-shadow: 0 0 12px rgba(74, 222, 128, 0.3); /* Hiệu ứng tỏa sáng nhẹ quanh nút */
  }

  /* Trạng thái nút bị khóa (Ví dụ đang ở trang 1 thì nút quay lại ◀ bị mờ) */
